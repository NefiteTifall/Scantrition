# App URL (required in production for password reset emails)
APP_URL=https://yourdomain.com

# Database
DATABASE_URL=postgresql://scantrition:scantrition@localhost:5432/scantrition

# Auth — generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-me-to-a-random-32-char-string-minimum

# Email (required for password reset)
RESEND_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# AI Providers (users can also set keys via the Settings UI)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
